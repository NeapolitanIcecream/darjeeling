 from typing import Any
 
 
+_EMAIL_SLOTLESS_FROM_ALLOWLIST = {"work"}
+
+
+def _has_any(text: str, needles: tuple[str, ...]) -> bool:
+    return any(needle in text for needle in needles)
+
+
+def _email_from_term(utterance: str) -> str | None:
+    marker = " from "
+    normalized = f" {utterance.lower()} "
+    if marker not in normalized:
+        return None
+    suffix = normalized.split(marker, 1)[1].strip()
+    if not suffix:
+        return None
+    return suffix.split()[0]
+
+
+def _veto_slotless_email_query(utterance: str) -> bool:
+    normalized = f" {utterance.lower()} "
+    from_term = _email_from_term(utterance)
+    if from_term and from_term not in _EMAIL_SLOTLESS_FROM_ALLOWLIST:
+        return True
+    return _has_any(normalized, (" inbox", "inbox ", " yahoo ", " today "))
+
+
+def _veto_slotless_prediction(intent: str, utterance: str) -> bool:
+    normalized = f" {utterance.lower()} "
+    if intent == "email_query":
+        return _veto_slotless_email_query(utterance)
+    if intent == "email_sendemail":
+        return _has_any(normalized, (" to my ", " to caroline ", " to john "))
+    if intent == "lists_createoradd":
+        return " list" in normalized
+    if intent == "lists_query":
+        return _has_any(normalized, (" things i need", " today "))
+    if intent == "alarm_query":
+        return _has_any(normalized, (" week ", " days ", " next two "))
+    if intent == "calendar_set":
+        return _has_any(normalized, (" remind ", " meeting ", " tomorrow "))
+    return False
+
+
