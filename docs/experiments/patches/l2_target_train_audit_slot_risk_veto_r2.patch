+    return False
+
+
+def _social_post_extra_person_risky(utterance: str, slots: dict[str, Any]) -> bool:
+    person = str(slots.get("person") or "").lower()
+    if not person:
+        return False
+    person_tokens = set(_WORD_RE.findall(person))
+    return bool(person_tokens and not person_tokens <= _tokens(utterance))
