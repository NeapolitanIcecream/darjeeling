+_AUDIO_AMOUNT_STOP_TERMS = {
+    "and",
+    "for",
+    "in",
+    "on",
+    "please",
+    "the",
+    "volume",
+}
+
+
+def _email_from_person(utterance: str) -> str | None:
+    marker = " from "
+    normalized = f" {utterance.lower()} "
+    if marker not in normalized:
+        return None
+    suffix = normalized.split(marker, 1)[1].strip()
+    if not suffix:
+        return None
+    terms: list[str] = []
+    for raw in suffix.split():
+        term = raw.strip(".,!?;:")
+        if not term or term in _PERSON_STOP_TERMS:
+            break
+        terms.append(term)
+        if len(terms) >= 3:
+            break
+    if not terms:
+        return None
+    if len(terms) == 1 and terms[0] in _NON_PERSON_FROM_TERMS:
+        return None
+    return " ".join(terms)
+
+
+def _audio_change_amount(utterance: str) -> str | None:
+    tokens = [token.strip(".,!?;:").lower() for token in utterance.split()]
+    tokens = [token for token in tokens if token]
+    for marker in ("to", "by"):
+        if marker not in tokens:
+            continue
+        start = tokens.index(marker)
+        amount = [marker]
+        for token in tokens[start + 1 :]:
+            if token in _AUDIO_AMOUNT_STOP_TERMS:
+                break
+            if token not in _AUDIO_AMOUNT_WORDS and not token.isdigit():
+                break
+            amount.append(token)
+            if len(amount) >= 4:
+                break
+        if len(amount) > 1:
+            return " ".join(amount)
+    return None
+
