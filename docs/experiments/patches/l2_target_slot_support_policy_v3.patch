+def _unsupported_slot_value_risky(
+    utterance: str,
+    intent: str,
+    slots: dict[str, Any],
+) -> bool:
+    if intent not in _SLOT_VALUE_SUPPORT_INTENTS:
+        return False
+    utterance_tokens = _canonical_tokens(utterance)
+    for slot_name, raw_value in slots.items():
+        value = str(raw_value or "")
+        value_tokens = _canonical_tokens(value)
+        if not value_tokens:
+            continue
+        if not value_tokens <= utterance_tokens:
+            return True
+        if intent == "recommendation_locations":
+            if _recommendation_location_slot_pair_risky(
+                slot_name=slot_name,
+                value_tokens=value_tokens,
+                slots=slots,
+            ):
+                return True
+    return False
 
 
+def _recommendation_location_slot_pair_risky(
+    *,
+    slot_name: str,
+    value_tokens: set[str],
+    slots: dict[str, Any],
+) -> bool:
+    if slot_name == "business_type" and len(value_tokens) > 4:
+        return True
+    if slot_name != "place_name" or "business_type" not in slots:
+        return False
+    business_tokens = _canonical_tokens(str(slots.get("business_type") or ""))
+    if not business_tokens:
+        return False
+    if business_tokens <= value_tokens:
+        return bool(value_tokens & _RECOMMENDATION_GENERIC_PLACE_MODIFIERS)
+    return False
+
+
+def _slotless_cue_risky(utterance: str, intent: str, slots: dict[str, Any]) -> bool:
+    if slots:
+        return False
+    cue_tokens = _SLOTLESS_CUE_TOKENS_BY_INTENT.get(intent)
+    if not cue_tokens:
+        return False
+    return bool(_canonical_tokens(utterance) & cue_tokens)
+
