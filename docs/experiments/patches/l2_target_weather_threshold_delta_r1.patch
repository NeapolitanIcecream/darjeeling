+def _tokens(utterance: str) -> list[str]:
+    return [
+        token.strip(".,!?;:").lower()
+        for token in utterance.split()
+        if token.strip(".,!?;:")
+    ]
+
+
+def _has_weather_date(utterance: str) -> bool:
+    return any(
+        token.startswith(prefix)
+        for token in _tokens(utterance)
+        for prefix in _WEATHER_DATE_PREFIXES
+    )
+
+
+def _has_any(utterance: str, terms: set[str]) -> bool:
+    return bool(set(_tokens(utterance)) & terms)
