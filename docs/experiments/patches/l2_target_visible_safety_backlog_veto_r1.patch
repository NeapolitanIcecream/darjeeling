+_JOKE_SLOT_REQUIRED_CUES = {
+    "best",
+    "funny",
+    "good",
+    "latest",
+    "silly",
+}
+
+_TRAFFIC_PLACE_PHRASES = (
+    " traffic in ",
+    " traffic on ",
+    " traffic from ",
+    " situation from ",
+    " situation right in ",
+    " to the home ",
+)
+
+_TRAFFIC_ROUTE_CUES = (
+    " broadway street ",
+    " i twenty five ",
+    " maiden lane ",
+    " washington town ",
+)
+
+_TRAFFIC_TIME_PHRASES = (
+    " this morning ",
+)
+
+_CALENDAR_TIME_CUES = (
+    " am ",
+    " pm ",
+    " ten am ",
+)
+
+_QUIRKY_NON_DATE_PHRASES = (
