+def _normalized(utterance: str) -> str:
+    return " " + " ".join(_WORD_RE.findall(utterance.lower())) + " "
+
+
+def _tokens(utterance: str) -> set[str]:
+    return set(_WORD_RE.findall(utterance.lower()))
+
+
+def _has_phrase(text: str, phrases: tuple[str, ...]) -> bool:
+    return any(phrase in text for phrase in phrases)
+
+
+def _slotless_currency_needs_slot(utterance: str) -> bool:
+    return bool(_tokens(utterance) & _CURRENCY_SLOT_REQUIRED_CUES)
+
+
+def _slotless_joke_needs_slot(utterance: str) -> bool:
+    text = _normalized(utterance)
+    tokens = _tokens(utterance)
+    if tokens & _JOKE_SLOT_REQUIRED_CUES:
+        return True
+    if " joke about " in text:
+        return True
+    if " today's joke" in text or " todays joke" in text:
+        return True
+    return False
+
+
+def _slotless_traffic_needs_slot(utterance: str) -> bool:
+    text = _normalized(utterance)
+    if " traffic to work " in text:
+        return False
+    if _has_phrase(text, _TRAFFIC_PLACE_PHRASES):
+        return True
+    if _has_phrase(text, _TRAFFIC_ROUTE_CUES):
+        return True
+    if " traffic " in text and _has_phrase(text, _TRAFFIC_TIME_PHRASES):
+        return True
+    return False
+
+
+def _quirky_extra_slot_risky(utterance: str, slots: dict[str, Any]) -> bool:
+    if set(slots) != {"date"}:
+        return False
+    text = _normalized(utterance)
+    date_value = str(slots.get("date") or "").lower()
+    if _has_phrase(text, _QUIRKY_NON_DATE_PHRASES):
+        return True
+    if date_value == "today" and " today " not in text:
+        return True
+    if "latest" in date_value and " latest " in text:
+        return True
+    return False
+
+
+def _calendar_set_mismatch_risky(utterance: str, slots: dict[str, Any]) -> bool:
+    text = _normalized(utterance)
+    frequency = str(slots.get("general_frequency") or "").lower()
+    if " every day " in text and frequency not in {"every day", "daily"}:
+        return True
+    if _has_phrase(text, _CALENDAR_TIME_CUES) and "time" not in slots:
+        return True
+    return False
+
+
