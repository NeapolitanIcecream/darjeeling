     return default_accept
+
+
+def _is_visible_general_quirky_date_hallucination(frame: dict[str, Any]) -> bool:
+    if frame.get("intent") != "general_quirky":
+        return False
+    slots = frame.get("slots") or {}
+    date = str(slots.get("date") or "").strip().lower()
+    if not date:
+        return False
+    temporal_tokens = {
+        "today",
+        "tomorrow",
+        "yesterday",
+        "tonight",
+        "week",
+        "month",
+        "year",
+    }
+    return not any(token in date for token in temporal_tokens)
+
+
+def _is_visible_email_person_hallucination(frame: dict[str, Any]) -> bool:
+    if frame.get("intent") != "email_query":
+        return False
+    slots = frame.get("slots") or {}
+    person = re.sub(r"[^a-z ]+", " ", str(slots.get("person") or "").lower())
+    return bool(re.search(r"\b(any|new)?\s*emails?\b", person))
