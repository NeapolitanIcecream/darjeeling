 import json
 from pathlib import Path
 from typing import Any
 
 
+_NON_PERSON_FROM_TERMS = {"work"}
+_PERSON_STOP_TERMS = {
+    "about",
+    "asking",
+    "at",
+    "for",
+    "in",
+    "on",
+    "please",
+    "regarding",
+    "saying",
+    "that",
+    "to",
+    "with",
+}
+
+
+def _email_from_person(utterance: str) -> str | None:
+    marker = " from "
+    normalized = f" {utterance.lower()} "
+    if marker not in normalized:
+        return None
+    suffix = normalized.split(marker, 1)[1].strip()
+    if not suffix:
+        return None
+    terms: list[str] = []
+    for raw in suffix.split():
+        term = raw.strip(".,!?;:")
+        if not term or term in _PERSON_STOP_TERMS:
+            break
+        terms.append(term)
+        if len(terms) >= 3:
+            break
+    if not terms:
+        return None
+    if len(terms) == 1 and terms[0] in _NON_PERSON_FROM_TERMS:
+        return None
+    return " ".join(terms)
+
+
