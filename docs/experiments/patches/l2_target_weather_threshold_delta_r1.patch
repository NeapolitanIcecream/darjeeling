+def _accept_email_query(utterance: str, slots: dict[str, Any]) -> bool:
+    slot_names = set(slots)
+    if slot_names - {"person"}:
+        return False
+    tokens = set(_tokens(utterance))
+    if not (tokens & _EMAIL_QUERY_TERMS):
+        return False
+    if tokens & _EMAIL_TEMPORAL_TERMS:
+        return False
+    if not slot_names and tokens & _EMAIL_RISK_TERMS:
+        return False
+    person = str(slots.get("person", "")).lower()
+    if person and (set(person.split()) & (_EMAIL_RISK_TERMS | {"olly"})):
+        return False
+    return True
+
+
+def _accept_audio_volume(utterance: str, intent: str, slots: dict[str, Any]) -> bool:
+    slot_names = set(slots)
+    if slot_names - {"change_amount"}:
+        return False
+    tokens = set(_tokens(utterance))
+    if intent == "audio_volume_up":
+        return bool(tokens & {"increase", "louder", "raise", "raised", "up"}) and not bool(
+            tokens & {"decrease", "down", "lower", "mute", "quiet"}
+        )
+    if intent == "audio_volume_down":
+        return bool(tokens & {"decrease", "down", "lower", "quieter"}) and not bool(
+            tokens & {"increase", "louder", "mute", "raise", "up"}
+        )
+    if intent == "audio_volume_mute":
+        return bool(tokens & {"mute", "quiet", "silence", "silent"})
+    if intent == "audio_volume_other":
+        return "volume" in tokens and bool(tokens & {"adjust", "change"})
+    return False
+
+
+def _accept_weather_query(utterance: str, slots: dict[str, Any]) -> bool:
+    slot_names = set(slots)
+    normalized = f" {utterance.lower()} "
+    if slot_names - _WEATHER_SLOT_NAMES:
+        return False
+    if "." in utterance and "place_name" in slot_names:
+        return False
+    if " in " in normalized and "place_name" not in slot_names:
+        return False
+    if " for " in normalized and not ({"date", "place_name"} & slot_names):
+        return False
+    if _has_weather_date(utterance) and "date" not in slot_names:
+        return False
+    if (
+        _has_any(utterance, _WEATHER_DESCRIPTOR_TERMS)
+        and "weather_descriptor" not in slot_names
+        and "weather" not in set(_tokens(utterance))
+    ):
+        return False
+    if not slot_names and (
+        " in " in normalized
+        or " for " in normalized
+        or _has_weather_date(utterance)
+        or _has_any(utterance, _WEATHER_DESCRIPTOR_TERMS)
+    ):
+        tokens = set(_tokens(utterance))
+        if not (tokens <= {"news", "weather"} or "there" in tokens):
+            return False
+    return True
+
