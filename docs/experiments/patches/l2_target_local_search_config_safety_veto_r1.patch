@@ -29,4 +30,37 @@ def accept_prediction(
 ) -> bool | None:
     """Return False to veto a guard accept; True/None keep the default decision."""
-    del utterance, frame, metadata
+    del metadata
+    if not default_accept:
+        return default_accept
+    if _is_visible_general_quirky_date_hallucination(frame):
+        return False
+    if _is_visible_email_person_hallucination(frame):
