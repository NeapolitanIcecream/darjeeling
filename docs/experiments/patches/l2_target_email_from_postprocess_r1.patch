 import json
 from pathlib import Path
 from typing import Any
 
 
+_NON_PERSON_FROM_TERMS = {"work"}
+
+
+def _email_from_person(utterance: str) -> str | None:
+    marker = " from "
+    normalized = f" {utterance.lower()} "
+    if marker not in normalized:
+        return None
+    suffix = normalized.split(marker, 1)[1].strip()
+    if not suffix:
+        return None
+    term = suffix.split()[0].strip(".,!?;:")
+    if not term or term in _NON_PERSON_FROM_TERMS:
+        return None
+    return term
+
+
